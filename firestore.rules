rules_version = '2';

// NOTA: reglas interinas mientras se construyen los módulos 3-6.
// Se reemplazan por las reglas finales (admin vs cliente, granulares por
// colección) en el módulo dedicado: specs/firestore-rules.spec.md.
service cloud.firestore {
  match /databases/{database}/documents {
    // Flag público mínimo para que el chequeo de "¿ya existe un admin?"
    // pueda correr antes de que haya sesión iniciada, sin exponer la
    // colección users (que sí tiene emails) a lectura anónima.
    match /meta/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
