rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function adminAlreadySeeded() {
      return exists(/databases/$(database)/documents/meta/adminSeeded);
    }

    // El admin seed (creado automáticamente al iniciar el sistema, ver
    // módulo auth) es el único que puede quitarle el rol de admin —o
    // borrar la cuenta— a OTRO admin. El resto de los admins hacen ABM
    // normal (cines/salas/funciones/usuarios) pero no pueden tocar el
    // estatus de otros admins.
    function esAdminSeed() {
      return request.auth.token.email == 'admin@gestioncine-scanio-tabuada.local';
    }

    function esDemocionDeAdmin() {
      return resource.data.role == 'admin' && request.resource.data.role != 'admin';
    }

    // Flag público mínimo para el chequeo de seed pre-login (ver módulo auth).
    match /meta/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      // Alta: el propio usuario se crea a sí mismo como "cliente".
      // Excepción de bootstrap: el seed inicial puede crearse como "admin"
      // únicamente mientras no exista ningún admin todavía.
      // Un admin ya logueado también puede crear el perfil de OTRO usuario
      // (p.ej. dar de alta a otro admin) con cualquier rol.
      allow create: if isSignedIn() && (
        (request.auth.uid == userId && (
          request.resource.data.role == 'cliente' ||
          (request.resource.data.role == 'admin' && !adminAlreadySeeded())
        )) ||
        isAdmin()
      );

      // Modificación (rol, disabled): solo admin. Ni el propio admin puede
      // quitarse a sí mismo el rol de admin, y ningún admin "regular"
      // puede quitarle el rol de admin a OTRO admin — eso es exclusivo
      // del admin seed.
      allow update: if isAdmin() &&
        !(request.auth.uid == userId && esDemocionDeAdmin()) &&
        !(request.auth.uid != userId && esDemocionDeAdmin() && !esAdminSeed());

      // Borrado del perfil (no borra la cuenta de Firebase Auth
      // subyacente — eso requeriría Admin SDK/backend, fuera de alcance
      // de un frontend puro; ver spec). Nadie se borra a sí mismo. Borrar
      // a un admin es exclusivo del admin seed, igual que desadminizarlo.
      allow delete: if isAdmin() && request.auth.uid != userId && (
        resource.data.role != 'admin' || esAdminSeed()
      );
    }

    // Lectura pública (sin login): catálogo de cines/salas/funciones y el
    // mapa de butacas ocupadas — navegar y ver disponibilidad no requiere
    // cuenta (módulo catálogo público). La escritura sigue exigiendo admin.
    match /cines/{cineId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /salas/{salaId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /funciones/{funcionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // create vs update: si el doc ya existe, "create" no matchea y cae en
    // "update" (solo admin) — refuerzo a nivel reglas de la transacción
    // atómica del módulo de compra de entradas.
    match /boletos/{ticketId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
